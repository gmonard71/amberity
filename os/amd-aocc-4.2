ARG DOCKER_HUB=""
FROM ${DOCKER_HUB}ubuntu:22.04

ARG AMD_MAJOR=aocc-4-2
ARG AMD_TAR=aocc-compiler-4.2.0.tar
ARG AMD_URL=https://download.amd.com/developer/eula/aocc
ARG AMD_PKG=${AMD_URL}/${AMD_MAJOR}/${AMD_TAR}

ENV DEBIAN_FRONTEND=noninteractive
ENV TZ=Europe/Paris
RUN  ln -snf /usr/share/zoneinfo/$TZ /etc/localtime && \
     apt-get update && apt-get install -y \
        python3 \
        tcsh make \
        gcc gfortran g++ \
        flex bison patch wget \
        bc xorg-dev libbz2-dev rsync openssh-client

# specific for AMD AOCC
RUN apt-get install -y libncurses5-dev xz-utils

RUN cd /tmp && \
    wget -O /tmp/${AMD_TAR} ${AMD_PKG} && \
    tar xf /tmp/${AMD_TAR} -C /opt && \
    cd /opt && mv aocc-* aocc

ENV AOCC_INS_DIR="/opt/aocc"
ENV PATH=$AOCC_INS_DIR/bin:$AOCC_INS_DIR/share/opt-viewer:$PATH
ENV LIBRARY_PATH=$AOCC_INS_DIR/lib:$AOCC_INS_DIR/lib32:/usr/lib/x86_64-linux-gnu:/usr/lib64:/usr/lib32:/usr/lib:$LIBRARY_PATH
ENV LD_LIBRARY_PATH=$AOCC_INS_DIR/ompd:$AOCC_INS_DIR/lib:$AOCC_INS_DIR/lib32:/usr/lib/x86_64-linux-gnu:/usr/lib64:/usr/lib32:/usr/lib:$LD_LIBRARY_PATH
ENV C_INCLUDE_PATH=$C_INCLUDE_PATH:$AOCC_INS_DIR/include
ENV CPLUS_INCLUDE_PATH=$CPLUS_INCLUDE_PATH:$AOCC_INS_DIR/include

