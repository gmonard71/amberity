ARG DOCKER_HUB=""
FROM ${DOCKER_HUB}fedora:43

RUN dnf -y update \
 && dnf -y install tcsh make \
                   gcc gcc-gfortran gcc-c++ \
                   which flex bison patch bc \
                   libXt-devel libXext-devel \
                   perl util-linux diffutils wget \
                   bzip2 bzip2-devel zlib-devel \
                   python3 rsync openssh openssh-clients hostname
