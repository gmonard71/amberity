    raise RuntimeError("\nConfiguration file {} does not exist".format(config_path))
with open(config_path) as f:
    config_file = yaml.load(f,Loader=yaml.Loader)

# setup configuration (override default with the config file)
config=Config()
docker=Docker()
singularity=Singularity()
config.fromYaml(config_file)
if 'docker' in config_file: docker.fromYaml(config_file['docker'])
if 'singularity' in config_file: singularity.fromYaml(config_file['singularity'])
# read image definitions
images=Images()
images.load(config_file)

if args.list is not None:
    # amberity image list <...>
    frmt = "{:<30s} {:>15s} {:>10s} {:>30s} {:>15s} {:>10s}"
    print(frmt.format("IMAGE_NAME","TYPE","EXISTS?","CREATED_AT","SIZE", "UP-TO-DATE"))
    if args.list == 'all':
        for image in images:
            exists, date, size, update = image.check()
            process=True
            if args.docker and image.type != 'docker': process=False
            if args.singularity and image.type != 'singularity': process=False
            if process: print(frmt.format(image.name,image.type,str(exists),date,size,str(not update)))
    else:
        for image in images:
            if image.name == args.list:
                exists, date, size, update = image.check()
                print(frmt.format(image.name,image.type,str(exists),date,size,str(not update)))
elif args.build is not None:
    # amberity image build <...>
    if args.docker is False and args.singularity is False:
        raise RuntimeError("\na container image should be provided using either the --docker or --singularity argument")
    elif args.singularity:
        singularity_target = images.find(args.build[0],'singularity')
        docker_target = images.find(args.build[0],'docker')
        docker.build(docker_target)
        singularity.build(singularity_target)
    elif args.docker:
        docker_target = images.find(args.build[0],'docker')
        docker.build(docker_target)
elif args.save is not None:
    # amberity image save <...>
    if args.docker is False and args.singularity is False:
        raise RuntimeError("\na container image should be provided using either the --docker or --singularity argument")
    elif args.singularity:
        raise RuntimeError("\nsave command is not supported with singularity")
    elif args.docker:
        docker_target = images.find(args.save[0],'docker')
        docker.save(docker_target)
elif args.avail is not None:
    # amberity image avail <...>
    if args.avail == 'all':
        for image in images:
            exists, date, size, update = image.check()
            process=True
            if args.docker and image.type != 'docker': process=False
            if args.singularity and image.type != 'singularity': process=False
           #if process and exists: print(image.name)
            if process: print(image.name)
    else:
        for image in images:
            if image.name == args.avail:
                process=True
                exists, date, size, update = image.check()
                if args.docker and image.type != 'docker': process=False
                if args.singularity and image.type != 'singularity': process=False
                if process:
                    if exists:
                        print(image.name)
                    else:
                        print("image not available")
elif args.container is not None:
    container = args.container[0]
    if args.docker is False and args.singularity is False:
        raise RuntimeError("\na container image should be provided using either the --docker or --singularity argument")
    if args.docker:
        docker_target = images.find(container,'docker')
        app = Application(docker_target,docker=docker,config=config,logfile=logfile)
    if args.singularity:
        singularity_target = images.find(container,'singularity')
        app = Application(singularity_target,singularity=singularity,config=config,logfile=logfile)
    if args.actions[0] == 'exec':
            app.appExec(args.actions[1:])
    elif args.actions[0] == 'cudaexec':
            app.appCudaExec(args.actions[1:])
    else:
        for action in args.actions:
            app.apply(action)
else:
    print('Nothing done...')

