class Image(Global):
    def __init__(self,defaultConfig):
        self.name=None
        self.type=None
        self.path=None
        default={
           'compiler': 'gnu',
           'openmp': False,
           'mpi': False,
           'cuda': False,
           'x11': True,
           'quick': True,
           'do_parallel': 'openmpi',
        }
        for key in default:
            if key in defaultConfig:
                # use the default config setup
                self.__dict__[key] = defaultConfig[key]
            else:
                self.__dict__[key] = default[key]

    def check(self):
        # check existence, date of creation and size (if any)
        if os.path.exists(self.path):
            exists=True
            date =  datetime.datetime.fromtimestamp(os.path.getctime(self.path)).strftime('%Y-%m-%d %H:%M:%S')
            size = os.path.getsize(self.path)
            unit='B'
            if size > 1024: size, unit = size/1024, 'KB'
            if size > 1024: size, unit = size/1024, 'MB'
            if size > 1024: size, unit = size/1024, 'GB'
            size='{:.2f}{}'.format(size,unit)
        else:
            exists=False
            date=""
            size=""
        update=False
        dependencies = [ 'os/{}'.format(self.name), 'template/cmake', 'template/user']
        if not os.path.exists(self.path):
            update=True
        else:
            for depend in dependencies:
                if os.path.getmtime(depend) > os.path.getmtime(self.path):
                    update=True
        return exists, date, size, update

class Images(list):
    def load(self,config_file):
        for image_spec in config_file['images']:
            image = Image(defaultConfig=config_file)
            image.fromYaml(image_spec)
            self += [image]
    def find(self,name,itype):
        """find a container named 'name' for type 'itype' (docker or singularity)"""
        if itype == 'singularity':
            singularity_target=None
            for image in images:
                if image.name == name and image.type == 'singularity':
                    singularity_target = image
                    break
            if singularity_target is None:
                raise RuntimeError("\nCan't find a valid image definition for type(singularity) and name({}) in the configuration file".format(name))
            return singularity_target
        if itype == 'docker':
            docker_target=None
            for image in images:
                if image.name == name and image.type == 'docker':
                    docker_target = image
                    break
            if docker_target is None:
                raise RuntimeError("\nCan't find a valid image definition for type(docker) and name({}) in the configuration file".format(name))
            return docker_target
        return None

class Application(object):
    def __init__(self,image,config=None,singularity=None,docker=None,logfile=None):
        self.image = image
        self.config = config
        self.docker = docker
        self.singularity = singularity
        self.image.work_dir = os.path.join(self.config.work_dir,self.image.name)
        if not os.path.exists(self.image.path):
            raise RuntimeError('\nImage "{}" does not exit, please build the image first'.format(self.image.name))
        self.amber_root = '/app'
        self.amber_version = self.config.amber_version
        self.amber_source = self.config.amber_version+'_src'
        if logfile is not None:
            logdir=os.path.dirname(os.path.abspath(logfile))
            if not args.dry_run:
                if not os.path.exists(logdir): os.makedirs(logdir)
                self.log = open(logfile,'w')
                self.logerr = subprocess.STDOUT
            else:
                self.log=None
                self.logerr=None
        else:
            self.log=None
            self.logerr=None

    def apply(self,action):
        valid_action = {'help':   self.appHelp,
                        'shell':  self.appShell,
                        'cudashell':  self.appCudaShell,
                        'exec':  self.appExec,
                        'cudaexec':  self.appCudaExec,
                        'clone':  self.appClone,
                        'update': self.appUpdate,
                        'clean':  self.appClean,
                        'cmake':  self.appCmake,
                        'configure': self.appConfigure,
                        'build':  self.appBuild,
                        'install':  self.appBuild,
                        'build_configure':  self.appOldBuild,
                        'install_configure':  self.appOldBuild,
                        'test.serial':  self.appTestSerial,
                        'test.openmp':  self.appTestOpenMP,
                        'test.mpi':  self.appTestParallel,
                        'test.parallel':  self.appTestParallel,
                        'test.cuda.serial':  self.appTestCudaSerial,
                        'test.cuda.parallel':  self.appTestCudaParallel,
                        'install.openmpi': self.appInstallOpenMPI,
                        'report': self.appReport,
                       }
        if action not in valid_action:
            raise RuntimeError('\naction "{}" is not a valid action.\nValid actions are {}'.format(action,',\n\t'.join(sorted(list(valid_action)))))
        valid_action[action]()

    def appHelp(self):
        print("""Available actions:
- help
- shell
- cudashell
- exec
- cudaexec
- clone
- update
- clean
- cmake
- configure ("old" configure setup)
- build|install
- build_configure|install_configure (build after configure)
- test.serial
- test.openmp
- test.parallel|test.mpi
- test.cuda.serial
- test.cuda.parallel
- install.openmpi
- report
""")

    def singularity_exec(self,thecommand,pwd=None,message=None,nvidia=False):
        commands = "{singularity}".format(singularity=self.singularity.path)
        commands += " {exec_cmd}".format(exec_cmd=self.singularity.exec_cmd)
        if nvidia: commands += " --nv"
        if pwd is not None: commands += " --cwd {pwd}".format(pwd=pwd)
        commands += "  --bind {source_dir}:/src".format(source_dir=self.config.source_dir)
        commands += "  --bind {work_dir}:{amber_root}".format(work_dir=self.image.work_dir,amber_root=self.amber_root)
        if self.config.miniconda_dir is not None: commands += "  --bind {miniconda_dir}:{miniconda_local}".format(miniconda_dir=self.config.miniconda_dir,miniconda_local=miniconda_container_location)
        commands += " {sif}".format(sif=self.image.path)
        commands += " {thecommand}".format(thecommand=thecommand)
       #if args.verbose: print("Executing:\n   {}".format(commands))
        if args.verbose and message is not None: print(message)
        if args.dry_run:
            print(commands)
        else:
            subprocess.run(commands,check=True,shell=True,stdout=self.log,stderr=self.logerr)

    def singularity_shell(self,message=None,nvidia=False):
        commands = "{singularity}".format(singularity=self.singularity.path)
        commands += " {shell_cmd}".format(shell_cmd=self.singularity.shell_cmd)
        if nvidia: commands += " --nv"
        commands += "  --bind {source_dir}:/src".format(source_dir=self.config.source_dir)
        commands += "  --bind {work_dir}:{amber_root}".format(work_dir=self.image.work_dir,amber_root=self.amber_root)
        if self.config.miniconda_dir is not None: commands += "  --bind {miniconda_dir}:{miniconda_local}".format(miniconda_dir=self.config.miniconda_dir,miniconda_local=miniconda_container_location)
        commands += " {sif}".format(sif=self.image.path)
       #if args.verbose: print("Executing:\n   {}".format(commands))
        if args.verbose and message is not None: print(message)
        if args.dry_run:
            print(commands)
        else:
            subprocess.run(commands,check=False,shell=True)

    def appClone(self):
        message = 'Cloning...'
        if not os.path.exists(self.image.work_dir) and not args.dry_run: os.makedirs(self.image.work_dir)
        if self.image.type == 'singularity':
            self.singularity_exec('mkdir -p {amber_root}/{amber_source}'.format(amber_root=self.amber_root,amber_source=self.amber_source))
            self.singularity_exec('rsync -a --delete --exclude=.git /src/. {amber_root}/{amber_source}'.format(amber_root=self.amber_root,amber_source=self.amber_source),message=message)

    def appUpdate(self):
        message = "Updating amber..."
        if self.config.proxy is None:
            self.singularity_exec('./update_amber --update',pwd=os.path.join(self.amber_root,self.amber_source),message=message)
        else:
            self.singularity_exec('./update_amber --proxy={proxy} --update'.format(proxy=self.config.proxy),pwd=os.path.join(self.amber_root,self.amber_source),message=message)

    def appClean(self):
        message = 'Cleaning build directory...'
        self.singularity_exec('./clean_build -f',pwd=os.path.join(self.amber_root,self.amber_source,'build'),message=message)

    def appCmake(self):
        message = "Configuring with cmake..."
        command = ''
       #command = 'bash -c "'
       #command += 'export PATH={amber_root}/{amber_version}/bin:$PATH && '.format(amber_root=self.amber_root,amber_version=self.amber_version)
       #command += 'export LD_LIBRARY_PATH={miniconda_dir}/lib:$LD_LIBRARY_PATH && '.format(miniconda_dir=miniconda_container_location)
        command += './configure_cmake.py --source {amber_root}/{amber_source} --prefix {amber_root}/{amber_version}'.format(amber_root=self.amber_root,amber_source=self.amber_source,amber_version=self.amber_version)
        command += " --no-reaxff"
        command += " --no-check-updates"
        command += " --no-apply-updates"
        command += " --compiler {}".format(self.image.compiler)
        if self.image.openmp: command += " --openmp"
        if self.image.mpi: command += " --mpi"
        if self.image.cuda: command += " --cuda"
        if not self.image.x11: command += " --no-gui"
        if self.config.pmemd_only: command += " --pmemd-only"
        if not self.image.quick: command += " --no-quick"
        if self.config.miniconda:
            if self.config.miniconda_dir is not None:
                if not os.path.exists(os.path.join(self.config.miniconda_dir,'bin','python')):
                    raise RuntimeError("\nno python executable in '{}'".format(self.config.miniconda_dir))
                command += " --no-miniconda --with-python {}".format(os.path.join(miniconda_container_location,'bin','python'))
        else:
            command += " --no-python"
       #command +='"'
        self.singularity_exec(command,pwd=os.path.join(self.amber_root,self.amber_source,'build'),message=message)

    def appConfigure(self):
        message = "Configuring with configure..."
        command = ''
       #command = 'bash -c "'
       #command += 'export PATH={amber_root}/{amber_version}/bin:$PATH && '.format(amber_root=self.amber_root,amber_version=self.amber_version)
       #command += 'export LD_LIBRARY_PATH={miniconda_dir}/lib:$LD_LIBRARY_PATH && '.format(miniconda_dir=miniconda_container_location)
        command += "./configure"
        if self.image.openmp: command += " -openmp"
        if self.image.mpi: command += " -mpi"
        if self.image.cuda: command += " -cuda"
        command += " {compiler}".format(compiler=self.image.compiler)
       #command +='"'
        self.singularity_exec(command,pwd=os.path.join(self.amber_root,self.amber_source),message=message)

