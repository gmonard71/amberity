class Global(object):
    def __repr__(self):
        mystr = ""
        for key in self.__dict__:
            mystr += "{}: {}\n".format(key,self.__dict__[key])
        return mystr

    def toYaml(self):
        thedict = {}
        for key in self.__dict__:
            thedict[key] = self.__dict__[key]
        return thedict

    def fromYaml(self,yamlDict):
        for key in self.__dict__:
            if key in yamlDict: self.__dict__[key] = yamlDict[key]


class Docker(Global):
    def __init__(self):
        self.path = 'docker'
        self.build_cmd = 'build'
        self.save_cmd = 'save'

    def build(self,target):
        # mkdir .source
        # mkdir $(dirname $(path))
        build_dir = os.path.dirname(os.path.abspath(target.path))
        if not os.path.exists(build_dir) and not args.dry_run: os.makedirs(build_dir)
        if not os.path.exists('.source') and not args.dry_run: os.makedirs('.source')
        update=False
        dependencies = [ 'os/{}'.format(target.name), 'template/cmake', 'template/user']
        if not os.path.exists(target.path):
            update=True
        else:
            for depend in dependencies:
                if os.path.getmtime(depend) > os.path.getmtime(target.path):
                   #print("{} > {}".format(depend,target.path))
                    update=True
        if update:
            # save the name of the container (will be later present as /etc/amber-image-release)
            if not args.dry_run:
                with open(os.path.join('.source','amber-image-release'),'w') as f:
                    f.write("{}\n".format(target.name))
            # create the container
            command1="cat {dependencies} | {docker} {build_cmd} -t amber-{name}:latest -f- .source".format(dependencies=" ".join(dependencies),
                docker=self.path,
                build_cmd=self.build_cmd,
                name=target.name)
            if args.verbose: print("Executing:\n   {}".format(command1))
            if args.dry_run:
                print(command1)
            else:
                subprocess.run(command1,check=True,shell=True)
            # save the container to a file
            command2="{docker} {save_cmd} amber-{name}:latest | lbzip2 > {path}".format(docker=self.path,
                save_cmd=self.save_cmd,
                name=target.name,
                path=target.path)
            if args.verbose: print("Executing:\n   {}".format(command2))
            if args.dry_run:
                print(command2)
            else:
                subprocess.run(command2,check=True,shell=True)
        else:
            print("target {} is up to date".format(target.path))

    def save(self,target):
        # mkdir .source
        # mkdir $(dirname $(path))
        build_dir = os.path.dirname(os.path.abspath(target.path))
        if not os.path.exists(build_dir) and not args.dry_run: os.makedirs(build_dir)
        if not os.path.exists('.source') and not args.dry_run: os.makedirs('.source')
        update=False
        dependencies = [ 'os/{}'.format(target.name), 'template/cmake', 'template/user']
        if not os.path.exists(target.path):
            update=True
        else:
            for depend in dependencies:
                if os.path.getmtime(depend) > os.path.getmtime(target.path):
                   #print("{} > {}".format(depend,target.path))
                    update=True
        if update:
            # save the container to a file
            command2="{docker} {save_cmd} amber-{name}:latest | lbzip2 > {path}".format(docker=self.path,
                save_cmd=self.save_cmd,
                name=target.name,
                path=target.path)
            if args.verbose: print("Executing:\n   {}".format(command2))
            if args.dry_run:
                print(command2)
            else:
                subprocess.run(command2,check=True,shell=True)
        else:
            print("target {} is up to date".format(target.path))

